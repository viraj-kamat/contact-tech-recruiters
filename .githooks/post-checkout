#!/usr/bin/env bash
# After checkout (clone, branch switch, etc.), make sure we can decrypt.
set -euo pipefail

# post-checkout args: prev_head new_head flag(1=branch)
FLAG="${3:-1}"
# Skip file checkouts of single files when flag=0? Still need key if encrypted files appear.
REPO_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=../.gitencrypt/lib.sh
source "${REPO_ROOT}/.gitencrypt/lib.sh"

ensure_key "post-checkout"
