#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=../.gitencrypt/lib.sh
source "${REPO_ROOT}/.gitencrypt/lib.sh"

if ! filter_configured; then
  echo "repo-crypt: filters not configured. Run: .gitencrypt/setup.sh" >&2
  exit 1
fi

ensure_key "pre-commit"
"${REPO_ROOT}/.gitencrypt/verify_coverage.sh"
